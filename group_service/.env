# Group Service — Docker Compose (service hostnames)
# For host uvicorn, swap hostnames → localhost and kafka:29092 → localhost:9092

DATABASE_URL=postgresql+asyncpg://studysync:studysync_dev@postgres_group:5432/group_db

REDIS_URL=redis://redis:6379/2

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=group-service
KAFKA_GROUP_EVENTS_TOPIC=GROUP_EVENTS

# Must match identity_service JWT_SECRET_KEY exactly
JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256

SESSION_SERVICE_URL=http://session_service:8001
SESSION_SERVICE_TIMEOUT_SECONDS=5.0
