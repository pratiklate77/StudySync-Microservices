# Copy to ".env" in this folder (identity_service/) before running Alembic or uvicorn.
# Defaults match repo-root docker-compose.yml (Postgres/Redis/Kafka on localhost).

# Postgres (compose: user studysync, password studysync_dev, db identity_db)
DATABASE_URL=postgresql+asyncpg://studysync:studysync_dev@postgres:5432/identity_db

REDIS_URL=redis://redis:6379

# Kafka — host port 9092 maps to PLAINTEXT_HOST (see docker-compose.yml)
#KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092 
KAFKA_CLIENT_ID=identity-service
KAFKA_USER_EVENTS_TOPIC=USER_EVENTS
KAFKA_RATING_EVENTS_TOPIC=RATING_EVENTS
KAFKA_CONSUMER_GROUP=identity-service-ratings

# Generate a real secret for anything beyond local dev, e.g. openssl rand -hex 32
JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

TOP_TUTORS_CACHE_KEY=marketplace:top_tutors
TOP_TUTORS_CACHE_TTL_SECONDS=300

# Optional: enables POST /api/v1/tutors/{user_id}/verify (emits TUTOR_VERIFIED to Kafka)
ADMIN_API_KEY=aniket

# --- Future Session service (not used by Identity today) ---
# MONGODB_URL=mongodb://localhost:27017/session_db
