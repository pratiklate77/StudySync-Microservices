# Copy to ".env" before running uvicorn locally.
# Defaults match repo-root docker-compose.yml when the service runs on the host.
# Inside Docker Compose use mongo:27017 instead of localhost:27017.

MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=session_db

REDIS_URL=redis://redis:6379/1

# Kafka — use kafka:29092 inside Docker
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CLIENT_ID=session-service
KAFKA_PAYMENT_EVENTS_TOPIC=PAYMENT_EVENTS
KAFKA_USER_EVENTS_TOPIC=USER_EVENTS
KAFKA_RATING_EVENTS_TOPIC=RATING_EVENTS
KAFKA_CONSUMER_GROUP=session-service-group

# MUST match identity service JWT_SECRET_KEY exactly — shared secret, decode-only
JWT_SECRET_KEY=7365442b87f806a755d470e209bff3a3fabc452dcac0f26e13263636de3942c9
JWT_ALGORITHM=HS256

NEARBY_SESSIONS_CACHE_TTL_SECONDS=60
